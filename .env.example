# ─── QuestDB ─────────────────────────────────────────────────────────────────
QUESTDB_HOST=questdb
QUESTDB_HTTP_PORT=9000
QUESTDB_ILP_PORT=9000

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ─── Alerting (SMTP) ─────────────────────────────────────────────────────────
ALERT_EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_FROM=you@gmail.com
ALERT_TO=you@gmail.com
# Number of consecutive failures before an alert is sent
ALERT_FAILURE_THRESHOLD=3

# ─── Failure log ─────────────────────────────────────────────────────────────
# Path inside the container — mount ./logs to persist across restarts
FAILURE_LOG_PATH=logs/failures.log

# ─── Deployment ──────────────────────────────────────────────────────────────
# GitHub repository in the format owner/repo — used by docker-compose.app.yml
# to resolve the container image from ghcr.io
GITHUB_REPOSITORY=your-github-username/historical-price-cron-archiver

# ─── General ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
